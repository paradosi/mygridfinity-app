# Copy to .env and fill values. Never commit a real .env.
# Real secrets live in 1Password (local) or Coolify env (prod).

# Database
DATABASE_URL=

# Redis (BullMQ)
REDIS_URL=

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 (STL cache)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM=

# Worker
RENDER_TIMEOUT_MS=
WORKER_CONCURRENCY=
